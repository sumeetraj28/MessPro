{
  "name": "messpro",
  "version": "2.0.0",
  "description": "MessPro - Mess Management System",
  "scripts": {
    "install:backend": "npm --prefix backend install",
    "install:frontend": "npm --prefix frontend install",
    "install:all": "npm run install:backend && npm run install:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build", // Only add if backend needs building
    "build": "npm run build:frontend",
    "start": "npm --prefix backend start",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "npm-run-all --parallel dev:backend dev:frontend"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
