{
  "name": "messpro",
  "version": "2.0.0",
  "description": "MessPro - Mess Management System",
  "main": "backend/index.js",
  "scripts": {
    "install:backend": "npm --prefix backend install",
    "install:frontend": "npm --prefix frontend install",
    "install:all": "npm run install:backend && npm run install:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "npm --prefix backend start",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "npm-run-all --parallel dev:backend dev:frontend"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sumeetraj28/MessPro.git"
  },
  "bugs": {
    "url": "https://github.com/sumeetraj28/MessPro/issues"
  },
  "homepage": "https://github.com/sumeetraj28/MessPro#readme",
  "keywords": [
    "mess",
    "management",
    "system",
    "nodejs",
    "react"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
