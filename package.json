{
  "name": "messpro",
  "version": "2.0.0",
  "description": "MessPro - Mess Management System",
  "scripts": {
    "prepare": "npm-run-all install:backend install:frontend",
    "install:backend": "npm --prefix backend install",
    "install:frontend": "npm --prefix frontend install",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix backend start",
    "dev": "npm --prefix backend run dev"
  },
  "dependencies": {
    "npm-run-all": "^4.1.5"
  }
}
